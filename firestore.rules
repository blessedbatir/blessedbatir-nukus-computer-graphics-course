rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidRegistration(data) {
      return data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100
          && data.phone is string && data.phone.size() >= 9 && data.phone.size() <= 20
          && data.courseId is string
          && data.createdAt == request.time;
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 200
          && data.slug is string && data.slug.size() <= 200
          && data.content is string && data.content.size() <= 50000
          && data.publishedAt is timestamp;
    }

    function isValidPortfolioItem(data) {
      return data.title is string && data.title.size() <= 100
          && data.studentName is string && data.studentName.size() <= 100
          && data.category is string
          && data.imageUrl is string && data.imageUrl.size() <= 1000;
    }

    function isValidSubscription(data) {
      return data.email is string && data.email.size() <= 255 && data.email.matches('^.+@.+\\..+$')
          && data.createdAt == request.time;
    }

    // --- Collections ---

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    match /registrations/{regId} {
      allow create: if isValidId(regId) && isValidRegistration(incoming());
      allow read, list, update, delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming());
      allow update: if isAdmin() && isValidBlogPost(incoming()) && incoming().publishedAt == existing().publishedAt;
      allow delete: if isAdmin();
    }

    match /portfolio/{itemId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidPortfolioItem(incoming());
      allow update: if isAdmin() && isValidPortfolioItem(incoming());
      allow delete: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow create: if isValidId(subId) && isValidSubscription(incoming());
      allow read, list: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
